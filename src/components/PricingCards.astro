---
import { localizeUrl, type Locale } from "../lib/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const appUrl = "https://app.futugrana.com";

interface Card {
  name: string;
  price: string;
  sub: string;
  bullets: string[];
  featured?: boolean;
  isContact?: boolean;
}

const t = locale === "it"
  ? {
      title: "Scegli il tuo piano.",
      sub: "Tutti i piani includono dashboard, esecuzione, multi-provider e registro operativo. La gestione per gli account in evaluation è gratuita; i piani si attivano sugli account funded.",
      mostChosen: "PIÙ SCELTO",
      contactCta: "Scopri di più →",
      startCta: "Inizia gratis →",
      perMonth: "/mese",
      cards: [
        { name: "Solo",        price: "€150",        sub: "1 slot · setup minimo",       bullets: ["1 account funded coordinato", "Dashboard, esecuzione, multi-provider", "Registro operativo integrato", "Account in evaluation sempre gratis"] },
        { name: "Team",        price: "€300",        sub: "3 slot · multi-account",      bullets: ["3 account funded in parallelo", "+ tutto del Solo", "Vista aggregata su più ambienti"], featured: true },
        { name: "Squadra",     price: "€400",        sub: "5 slot · operatività estesa", bullets: ["5 account funded in parallelo", "+ tutto del Team", "Supporto prioritario"] },
        { name: "Per Gestori", price: "Contattaci", sub: "Coordini una squadra di trader", bullets: ["Multi-trader con scoping per ognuno", "Dashboard aggregata", "Pricing concordato in base a trader e slot necessari"], isContact: true },
      ] as Card[],
    }
  : {
      title: "Choose your plan.",
      sub: "All plans include dashboard, execution, multi-provider and operational record. Evaluation accounts are free; plans activate on funded accounts.",
      mostChosen: "MOST CHOSEN",
      contactCta: "Learn more →",
      startCta: "Start free →",
      perMonth: "/month",
      cards: [
        { name: "Solo",         price: "€150",       sub: "1 slot · minimal setup",        bullets: ["1 funded account coordinated", "Dashboard, execution, multi-provider", "Built-in operational record", "Evaluation accounts always free"] },
        { name: "Team",         price: "€300",       sub: "3 slots · multi-account",       bullets: ["3 funded accounts in parallel", "+ everything in Solo", "Aggregated view across environments"], featured: true },
        { name: "Squadra",      price: "€400",       sub: "5 slots · extended operations", bullets: ["5 funded accounts in parallel", "+ everything in Team", "Priority support"] },
        { name: "For Managers", price: "Contact us", sub: "Coordinate a team of traders",  bullets: ["Multi-trader scoping per user", "Aggregated dashboard", "Custom pricing based on traders & slots needed"], isContact: true },
      ] as Card[],
    };
---
<section class="relative bg-paper px-8 py-28" style="z-index: 25;">
  <div class="max-w-[1200px] mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-[clamp(28px,3vw,44px)] font-semibold tracking-[-0.03em] leading-tight mb-5 text-ink">{t.title}</h2>
      <p class="text-base text-muted max-w-2xl mx-auto leading-relaxed" set:html={t.sub} />
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {t.cards.map((c) => {
        const cardClass = c.isContact
          ? "bg-ink text-paper border border-white/10"
          : c.featured
            ? "bg-accent-soft border border-accent/40"
            : "bg-surface border border-border";
        const subTextClass = c.isContact ? "text-paper/70" : "text-muted";
        const bulletTextClass = c.isContact ? "text-paper/85" : "text-ink/80";
        const checkClass = c.isContact ? "text-paper/50" : "text-accent";
        const ctaClass = c.isContact
          ? "bg-paper text-ink hover:bg-paper/90"
          : c.featured
            ? "bg-accent text-paper hover:bg-accent-hover"
            : "bg-ink text-paper hover:opacity-90";
        return (
          <div class:list={["relative rounded-2xl p-8 md:p-10 flex flex-col gap-6 transition-shadow hover:shadow-[0_1px_2px_rgba(15,23,42,0.04),0_8px_24px_-8px_rgba(15,23,42,0.08)]", cardClass]}>
            {c.featured && (
              <div class="absolute -top-2.5 right-6 px-2.5 py-1 bg-accent text-paper text-[10px] font-semibold tracking-[0.18em] rounded-full">{t.mostChosen}</div>
            )}
            <div>
              <h3 class="text-xl font-semibold tracking-tight mb-1.5">{c.name}</h3>
              <p class:list={["text-sm leading-relaxed", subTextClass]}>{c.sub}</p>
            </div>
            <div class="flex items-baseline gap-1">
              <span class="text-4xl font-semibold tracking-tight">{c.price}</span>
              {!c.isContact && <span class:list={["text-sm font-medium", subTextClass]}>{t.perMonth}</span>}
            </div>
            <ul class:list={["space-y-2.5 flex-1 text-sm leading-relaxed", bulletTextClass]}>
              {c.bullets.map((b) => (
                <li class="flex items-start gap-2.5">
                  <span class:list={["mt-0.5 inline-flex w-4 h-4 items-center justify-center text-[11px] font-semibold", checkClass]}>✓</span>
                  <span>{b}</span>
                </li>
              ))}
            </ul>
            <a
              href={c.isContact ? localizeUrl("/per-gestori", locale) : `${appUrl}/signup?ref=pricing-${c.name.toLowerCase()}`}
              class:list={[
                "inline-block text-center px-5 py-3 rounded-full text-sm font-semibold transition-colors",
                ctaClass,
              ]}
            >
              {c.isContact ? t.contactCta : t.startCta}
            </a>
          </div>
        );
      })}
    </div>
  </div>
</section>
