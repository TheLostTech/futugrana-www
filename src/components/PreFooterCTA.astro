---
import type { Locale } from "../lib/i18n";

interface Props { locale: Locale; }
const { locale } = Astro.props;
const appUrl = "https://app.futugrana.com";

const t = locale === "it"
  ? {
      title: "Operare su più ambienti<br>non deve essere un caos.",
      sub: "Collega i tuoi account e gestisci tutto da un'unica infrastruttura operativa. Niente carta di credito finché un account non passa a funded.",
      cta: "Inizia gratis →",
    }
  : {
      title: "Operating across multiple environments<br>shouldn't be chaos.",
      sub: "Connect your accounts and manage everything from a single operational infrastructure. No credit card until an account goes funded.",
      cta: "Start free →",
    };
---
<section class="bg-ink text-paper px-8 py-24 text-center relative" style="z-index: 25;">
  <div class="max-w-[1000px] mx-auto">
    <h2 class="text-[clamp(24px,3.5vw,60px)] font-black tracking-[-0.04em] leading-none mb-8 text-center" set:html={t.title} />
    <p class="text-xl opacity-80 max-w-2xl mx-auto mb-10 font-medium">{t.sub}</p>
    <a href={`${appUrl}/signup?ref=prefooter`} class="inline-block px-12 py-5 bg-paper text-ink rounded-full font-black text-lg hover:opacity-90">{t.cta}</a>
  </div>
</section>
