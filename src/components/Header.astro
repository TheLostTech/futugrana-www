---
import { localizeUrl, type Locale } from "../lib/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const t = locale === "it"
  ? {
      product: "Prodotto",
      pricing: "Prezzi",
      forManagers: "Per gestori",
      docs: "Docs",
      help: "Aiuto",
      login: "Accedi",
      cta: "Inizia gratis",
    }
  : {
      product: "Product",
      pricing: "Pricing",
      forManagers: "For managers",
      docs: "Docs",
      help: "Help",
      login: "Log in",
      cta: "Start free",
    };

const appUrl = "https://app.futugrana.com";
---
<header class="fixed top-0 inset-x-0 z-50 bg-[#E2E8F0] border-b border-black/[0.06] px-8 py-4">
  <div class="max-w-[1400px] mx-auto flex items-center justify-between gap-6">
    <a href={localizeUrl("/", locale)} class="text-[20px] font-semibold tracking-tight text-ink">
      Futugrana
    </a>

    <nav class="hidden md:flex items-center gap-6 text-sm font-semibold">
      <a href={localizeUrl("/", locale)} class="hover:opacity-70">{t.product} ▾</a>
      <a href={localizeUrl("/prezzi", locale)} class="hover:opacity-70">{t.pricing}</a>
      <a href={localizeUrl("/per-gestori", locale)} class="hover:opacity-70">{t.forManagers}</a>
      <a href={localizeUrl("/docs", locale)} class="hover:opacity-70">{t.docs}</a>
    </nav>

    <div class="flex items-center gap-2 text-sm font-semibold">
      <a href={localizeUrl("/faq", locale)} class="hidden md:inline px-3 py-2 hover:opacity-70">{t.help}</a>
      <a href={`${appUrl}/login`} class="px-5 py-2.5 rounded-full border border-ink hover:bg-ink hover:text-paper transition-colors">
        {t.login}
      </a>
      <a href={`${appUrl}/signup`} class="px-5 py-2.5 rounded-full bg-ink text-paper hover:opacity-90">
        {t.cta}
      </a>
    </div>
  </div>
</header>
<div class="h-[72px]" aria-hidden="true"></div>
