---
const props = [
  { name: "APEX-001",   provider: "TDV",  status: "funded" },
  { name: "FTMO-2",     provider: "META", status: "funded" },
  { name: "Topstep-A",  provider: "TDV",  status: "evaluation" },
  { name: "Lucid-LFF",  provider: "PRJ",  status: "evaluation" },
  { name: "Tradeify-1", provider: "TDV",  status: "funded" },
];
---
<div class="w-full h-full bg-ink text-paper flex items-center justify-center p-[clamp(20px,4vw,60px)]">
  <div class="grid grid-cols-2 md:grid-cols-3 gap-4 max-w-[900px] w-full">
    {props.map((p) => (
      <div class="bg-white/[0.04] border border-white/10 rounded-2xl p-5">
        <div class="flex items-start justify-between mb-3">
          <span class="text-[10px] font-mono px-2 py-0.5 bg-white/10 rounded text-paper/80 tracking-wide">{p.provider}</span>
          <span class:list={[
            "text-[10px] font-medium tracking-wider px-2 py-0.5 rounded-full border",
            p.status === "funded"
              ? "bg-accent/10 text-accent border-accent/30"
              : "bg-white/[0.04] text-paper/55 border-white/10",
          ]}>{p.status}</span>
        </div>
        <div class="text-base font-semibold tracking-tight">{p.name}</div>
      </div>
    ))}
    <div class="bg-white/[0.02] border border-dashed border-white/15 rounded-2xl p-5 flex items-center justify-center">
      <span class="text-sm text-paper/40">+ aggiungi</span>
    </div>
  </div>
</div>
