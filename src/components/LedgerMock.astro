---
const movements = [
  { sign: "+", amount: "€1.200", type: "Payout",     target: "APEX-001 → wallet primario", date: "22 mag" },
  { sign: "−", amount: "€295",   type: "Fee phase 2", target: "Lucid-LFF",                   date: "18 mag" },
  { sign: "+", amount: "€600",   type: "Versamento",  target: "Tradeify",                    date: "12 mag" },
];
---
<div class="w-full h-full bg-surface text-ink flex flex-col items-center justify-center gap-6 p-[clamp(20px,4vw,60px)]">
  <div class="bg-paper border border-[color:var(--color-border)] rounded-2xl divide-y divide-[color:var(--color-border)] max-w-[760px] w-full">
    {movements.map((m) => (
      <div class="flex items-center justify-between px-5 py-4">
        <div class="flex items-center gap-4">
          <span class:list={[
            "text-lg font-semibold w-20 tabular-nums tracking-tight",
            m.sign === "+" ? "text-accent" : "text-ink/55",
          ]}>{m.sign}{m.amount}</span>
          <div>
            <div class="text-sm font-medium text-ink">{m.type}</div>
            <div class="text-xs text-muted">{m.target}</div>
          </div>
        </div>
        <div class="text-xs font-mono text-subtle">{m.date}</div>
      </div>
    ))}
  </div>
  <div class="bg-ink text-paper rounded-2xl px-6 py-4 flex gap-6 text-sm">
    <span class="text-paper/70">Netto 30 giorni</span>
    <span class="text-accent font-semibold tabular-nums">€3.148</span>
    <span class="text-paper/20">·</span>
    <span class="text-paper/55">Tasse stimate <span class="tabular-nums">€1.029</span></span>
  </div>
</div>
