---
import { localizeUrl, type Locale } from "../lib/i18n";
import FlowConnectMock from "./FlowConnectMock.astro";
import FlowConfigureMock from "./FlowConfigureMock.astro";
import FlowActivateMock from "./FlowActivateMock.astro";
import FlowTrackMock from "./FlowTrackMock.astro";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const appUrl = "https://app.futugrana.com";

const t = locale === "it"
  ? {
      cta: "Prova subito gratis →",
      ctaSub: "Riscatta l'offerta · 1 account evaluation a tua scelta, nessuna scadenza temporale.",
      steps: [
        { title: "Connetti",  desc: "Colleghi i tuoi ambienti broker in pochi minuti. Tradovate via OAuth, MetaApi via token. Credenziali gestite in modo sicuro.", visual: { meta: "step 1 — onboarding", title: "Collega l'ambiente", icon: "🔗" } },
        { title: "Configura", desc: "Registri gli ID degli account che vuoi coordinare. La gestione operativa per gli account in evaluation è gratuita.", visual: { meta: "step 2 — setup", title: "Registra l'account", icon: "📥" } },
        { title: "Attiva",    desc: "Quando un account passa a funded, il sistema lo rileva e attiva la gestione operativa. Continui senza interruzioni.", visual: { meta: "step 3 — go-live", title: "Coordinamento attivo", icon: "⚡" } },
        { title: "Traccia",   desc: "Movimenti e registri operativi consultabili dalla dashboard. Il tuo registro contabile sempre allineato.", visual: { meta: "step 4 — registro", title: "Registro allineato", icon: "📊" } },
      ],
    }
  : {
      cta: "Try free now →",
      ctaSub: "Claim the offer · 1 evaluation account of your choice, no time limit.",
      steps: [
        { title: "Connect",   desc: "Connect your broker environments in minutes. Tradovate via OAuth, MetaApi via token. Credentials handled securely.", visual: { meta: "step 1 — onboarding", title: "Connect the environment", icon: "🔗" } },
        { title: "Configure", desc: "Register the account IDs you want to coordinate. Operational management is free for evaluation accounts.", visual: { meta: "step 2 — setup", title: "Register account", icon: "📥" } },
        { title: "Activate",  desc: "When an account goes funded, the system detects it and activates operational management. No interruptions.", visual: { meta: "step 3 — go-live", title: "Coordination live", icon: "⚡" } },
        { title: "Track",     desc: "Operational records and movements available from the dashboard. Your bookkeeping always in sync.", visual: { meta: "step 4 — record", title: "Records in sync", icon: "📊" } },
      ],
    };
---
<section data-flow class="relative h-[320vh] bg-blu" style="z-index: 15;">
  <div class="sticky top-0 h-screen text-paper grid grid-cols-1 md:grid-cols-2 items-center px-[clamp(40px,8vw,140px)] gap-15">
    <div class="flex flex-col gap-6">
      <div class="flex flex-col gap-3.5">
        {t.steps.map((s, i) => (
          <span
            data-flow-title
            data-active={i === 0 ? "true" : "false"}
            class="text-[clamp(24px,3.5vw,50px)] leading-[0.95] tracking-[-0.04em] font-black text-center transition-colors duration-500 data-[active=true]:text-paper data-[active=false]:text-paper/[0.22]"
          >{s.title}</span>
        ))}
      </div>
      <div class="min-h-[100px] max-w-[460px]">
        {t.steps.map((s, i) => (
          <p data-flow-desc class="text-lg leading-snug font-medium opacity-90 mb-7" style={i === 0 ? "display:block" : "display:none"}>{s.desc}</p>
        ))}
        <div class="flex flex-col items-start gap-3">
          <a href={`${appUrl}/signup?offer=trial`} class="inline-block px-7 py-3.5 bg-paper text-ink rounded-full font-semibold text-sm tracking-tight hover:bg-paper/90 transition-colors">
            {t.cta}
          </a>
          <p class="text-[13px] text-paper/65 leading-snug max-w-[420px]">{t.ctaSub}</p>
        </div>
      </div>
    </div>

    <div class="relative h-[75vh] rounded-3xl overflow-hidden bg-black/20">
      {t.steps.map((s, i) => (
        <div
          data-flow-slide
          data-position={i === 0 ? "active" : "next"}
          class="absolute inset-0 flex items-center justify-center p-[6%] transition-[transform,opacity] duration-700 ease-[cubic-bezier(0.65,0,0.25,1)] opacity-0
                 data-[position=active]:opacity-100 data-[position=active]:translate-y-0
                 data-[position=next]:translate-y-full
                 data-[position=prev]:-translate-y-full"
        >
          <div class="w-full h-full bg-paper rounded-2xl p-6 md:p-7 text-ink flex flex-col gap-4">
            <div class="flex items-center justify-between">
              <span class="text-[11px] uppercase tracking-[0.18em] text-muted font-medium">{s.visual.meta}</span>
            </div>
            <h4 class="text-xl font-semibold tracking-tight leading-tight">{s.visual.title}</h4>
            {i === 0 ? (
              <FlowConnectMock />
            ) : i === 1 ? (
              <FlowConfigureMock />
            ) : i === 2 ? (
              <FlowActivateMock />
            ) : (
              <FlowTrackMock />
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
