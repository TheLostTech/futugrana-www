---
---
<div class="flex-1 bg-ink rounded-2xl border border-white/[0.06] overflow-hidden flex flex-col">
  <div class="px-5 pt-4 pb-3 border-b border-white/[0.06] flex items-center justify-between">
    <div class="flex items-center gap-2 min-w-0">
      <span class="text-accent text-[14px] leading-none">⚡</span>
      <div class="text-[13px] font-semibold text-paper tracking-tight truncate">
        Quick Trade · <span class="font-mono text-paper/65 text-[12px]">AFPRMEV…14399</span>
      </div>
    </div>
    <span class="text-paper/35 text-base leading-none">×</span>
  </div>

  <div class="px-5 pt-3">
    <div class="grid grid-cols-2 gap-2">
      <div class="bg-accent/15 border border-accent/40 text-accent rounded-lg py-2 text-[11px] font-semibold tracking-wide flex items-center justify-center gap-1.5">
        <span class="text-[10px]">↗</span> BUY PROP
      </div>
      <div class="bg-white/[0.03] border border-white/10 text-paper/55 rounded-lg py-2 text-[11px] font-medium tracking-wide flex items-center justify-center gap-1.5">
        <span class="text-[10px]">↘</span> SELL PROP
      </div>
    </div>
  </div>

  <div class="px-5 pt-4">
    <div class="flex items-center justify-between mb-2">
      <div class="flex items-center gap-1.5 text-[11px] font-semibold text-paper tracking-tight">
        <span class="w-1 h-3 rounded-sm bg-accent"></span>
        <span>PROP <span class="text-paper/45 font-medium">· Nasdaq</span></span>
      </div>
      <span class="text-[9px] px-1.5 py-0.5 rounded-full bg-white/[0.05] text-paper/55 border border-white/10 font-medium tracking-wider">Tradovate</span>
    </div>
    <div class="grid grid-cols-2 gap-2 mb-2">
      <div>
        <div class="text-[9px] uppercase tracking-[0.15em] text-paper/40 font-medium mb-1">Contratti</div>
        <div class="bg-white/[0.04] border border-white/[0.08] rounded-md px-2.5 py-1.5 text-[11px] font-mono text-paper tabular-nums">1</div>
      </div>
      <div>
        <div class="text-[9px] uppercase tracking-[0.15em] text-paper/40 font-medium mb-1">Account</div>
        <div class="bg-white/[0.04] border border-white/[0.08] rounded-md px-2.5 py-1.5 text-[11px] font-mono text-paper tabular-nums">1</div>
      </div>
    </div>
    <div class="grid grid-cols-2 gap-2">
      <div>
        <div class="text-[9px] uppercase tracking-[0.15em] text-paper/40 font-medium mb-1 flex items-center gap-1">
          <span class="w-1.5 h-1.5 rounded-sm bg-paper/30"></span> Stop Loss
        </div>
        <div class="bg-white/[0.04] border border-white/[0.08] rounded-md px-2.5 py-1.5 text-[11px] font-mono text-paper tabular-nums">2020</div>
      </div>
      <div>
        <div class="text-[9px] uppercase tracking-[0.15em] text-paper/40 font-medium mb-1 flex items-center gap-1">
          <span class="w-1.5 h-1.5 rounded-sm bg-accent"></span> Take Profit
        </div>
        <div class="bg-white/[0.04] border border-white/[0.08] rounded-md px-2.5 py-1.5 text-[11px] font-mono text-paper tabular-nums">1520</div>
      </div>
    </div>
  </div>

  <div class="px-5 pt-4 pb-4 flex-1">
    <div class="flex items-center justify-between mb-2">
      <div class="flex items-center gap-1.5 text-[11px] font-semibold text-paper tracking-tight">
        <span class="w-1 h-3 rounded-sm bg-paper/35"></span>
        <span>BROKER <span class="text-paper/45 font-medium">· NAS100</span></span>
      </div>
      <span class="text-[9px] px-1.5 py-0.5 rounded-full bg-white/[0.05] text-paper/55 border border-white/10 font-medium tracking-wider">MetaApi</span>
    </div>
    <div class="bg-white/[0.04] border border-white/[0.08] rounded-md px-3 py-2 mb-2 flex items-center justify-between">
      <span class="text-[9px] uppercase tracking-[0.15em] text-paper/45 font-medium">Copertura ($)</span>
      <span class="text-[12px] font-mono text-paper tabular-nums">500</span>
    </div>
    <div class="bg-white/[0.02] border border-white/[0.06] rounded-md px-3 py-2 space-y-1">
      <div class="flex justify-between text-[10px]">
        <span class="text-paper/55">Costo challenge</span>
        <span class="font-mono text-paper tabular-nums">$40</span>
      </div>
      <div class="flex justify-between text-[10px]">
        <span class="text-paper/55">Ideal chiusura</span>
        <span class="font-mono text-accent tabular-nums">+$50</span>
      </div>
      <div class="flex justify-between text-[10px] pt-1 border-t border-white/[0.06]">
        <span class="text-paper font-medium">Margine richiesto</span>
        <span class="font-mono text-paper tabular-nums">$500</span>
      </div>
    </div>
  </div>
</div>
