---
interface Props {
  bgClass: string;
  textClass?: string;
  titleClass?: string;
  eyebrow?: string;
  title?: string;
  wordTop: string;
  wordBottom: string;
  zIndex: number;
}
const {
  bgClass,
  textClass = "text-paper",
  titleClass = "text-ink",
  eyebrow,
  title,
  wordTop,
  wordBottom,
  zIndex,
} = Astro.props;
---
<section
  data-pattern-b
  class="relative h-[220vh] -mt-[100vh]"
  style={`z-index: ${zIndex};`}
>
  <div class:list={["sticky top-0 h-screen overflow-hidden", bgClass]}>
    <div class="absolute inset-0 z-[1]">
      <slot />
    </div>

    {eyebrow && (
      <p class:list={["absolute top-32 left-1/2 -translate-x-1/2 z-[5] text-xs uppercase tracking-[0.3em] font-semibold opacity-60", titleClass]}>
        {eyebrow}
      </p>
    )}

    {title && (
      <h2
        class:list={[
          "absolute top-[38%] left-1/2 -translate-x-1/2 -translate-y-1/2 z-[5]",
          "text-center leading-[0.95] tracking-[-0.04em] font-black",
          "text-[clamp(32px,5vw,80px)]",
          titleClass,
        ]}
        set:html={title}
      />
    )}

    <span
      class:list={[
        "absolute top-[14vh] left-[6vw] right-[6vw] z-[3] block text-left",
        "text-[clamp(50px,8.5vw,140px)] leading-[0.9] tracking-[-0.05em] font-black lowercase",
        textClass,
      ]}
    >{wordTop}</span>

    <span
      class:list={[
        "absolute bottom-[7vh] left-[6vw] right-[6vw] z-[3] block text-right",
        "text-[clamp(50px,8.5vw,140px)] leading-[0.9] tracking-[-0.05em] font-black lowercase",
        textClass,
      ]}
    >{wordBottom}</span>
  </div>
</section>
