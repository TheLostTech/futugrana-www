---
import ScenePatternA from "./ScenePatternA.astro";
import DashboardMock from "./DashboardMock.astro";
import { localizeUrl, type Locale } from "../lib/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const appUrl = "https://app.futugrana.com";

const t = locale === "it"
  ? {
      toggleTrader: "Trader",
      toggleManager: "Gestore",
      title: "Automazione operativa<br>per trader futures.",
      sub: "Sincronizzazione operativa, multi-broker e gestione event-driven in tempo reale. Il controllo resta al trader. L'infrastruttura pensa al coordinamento.",
      ctaPrimary: "Inizia gratis →",
      ctaMicro: "Provala gratis. Il piano si attiva solo sugli account funded.",
      ctaSecondary: "Scopri la piattaforma",
      wordLeft: "infrastruttura",
      wordRight: "operativa",
    }
  : {
      toggleTrader: "Trader",
      toggleManager: "Manager",
      title: "Operational automation<br>for futures traders.",
      sub: "Operational sync, multi-broker and event-driven management in real time. Trading decisions stay with the trader. The infrastructure handles coordination.",
      ctaPrimary: "Start free →",
      ctaMicro: "Try it free. The plan activates only on funded accounts.",
      ctaSecondary: "Explore the platform",
      wordLeft: "operational",
      wordRight: "infrastructure",
    };
---
<ScenePatternA
  bgClass="bg-celeste"
  textClass="text-ink"
  wordsClass="text-ink/[0.04]"
  eyebrow=""
  title={t.title}
  wordLeft={t.wordLeft}
  wordRight={t.wordRight}
  zIndex={10}
>
  <DashboardMock />
</ScenePatternA>

<div class="fixed top-[88px] left-1/2 -translate-x-1/2 z-[20] pointer-events-none" data-hero-overlay>
  <div class="bg-ink text-paper rounded-full p-1.5 inline-flex gap-0 text-sm font-bold pointer-events-auto">
    <span class="px-5 py-2 rounded-full bg-paper text-ink">{t.toggleTrader}</span>
    <a href={localizeUrl("/per-gestori", locale)} class="px-5 py-2 rounded-full hover:bg-white/10">{t.toggleManager}</a>
  </div>
</div>

<div class="fixed top-[55vh] left-1/2 -translate-x-1/2 z-[20] pointer-events-none text-center" data-hero-cta>
  <p class="text-ink/70 text-lg max-w-xl mx-auto mb-7 font-medium pointer-events-auto" set:html={t.sub} />
  <a href={`${appUrl}/signup`} class="inline-block px-9 py-4 bg-ink text-paper rounded-full font-bold pointer-events-auto hover:opacity-90">
    {t.ctaPrimary}
  </a>
  <p class="text-[13px] text-ink/60 mt-3 pointer-events-auto">{t.ctaMicro}</p>
  <p class="mt-2 pointer-events-auto">
    <a href={localizeUrl("/prezzi", locale)} class="text-sm text-accent underline underline-offset-4 decoration-accent/40 hover:decoration-accent transition-colors">{t.ctaSecondary}</a>
  </p>
</div>

<script is:inline>
  (function () {
    const overlay = document.querySelector("[data-hero-overlay]");
    const ctaBlock = document.querySelector("[data-hero-cta]");
    if (!overlay || !ctaBlock) return;
    function update() {
      const hide = window.scrollY > window.innerHeight * 0.5;
      overlay.style.opacity = hide ? "0" : "1";
      ctaBlock.style.opacity = hide ? "0" : "1";
      overlay.style.transition = "opacity 0.3s";
      ctaBlock.style.transition = "opacity 0.3s";
    }
    document.addEventListener("scroll", update, { passive: true });
    update();
  })();
</script>
