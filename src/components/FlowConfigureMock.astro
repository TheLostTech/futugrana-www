---
---
<div class="flex-1 bg-ink rounded-2xl border border-white/[0.06] overflow-hidden flex flex-col">
  <div class="px-5 pt-4 pb-3 border-b border-white/[0.06] flex items-center justify-between">
    <div class="flex items-center gap-2 min-w-0">
      <div class="text-[13px] font-semibold text-paper tracking-tight truncate">Crea nuova challenge</div>
      <span class="text-[9px] px-1.5 py-0.5 rounded-full bg-accent/10 text-accent border border-accent/30 font-medium tracking-[0.15em] uppercase">futures</span>
    </div>
    <span class="text-paper/35 text-base leading-none">×</span>
  </div>

  <div class="px-5 py-3.5 space-y-3 flex-1">
    <div>
      <label class="text-[10px] uppercase tracking-[0.15em] text-paper/45 font-medium block mb-1">Provider API <span class="text-paper/30 normal-case tracking-normal">(opzionale)</span></label>
      <div class="bg-white/[0.04] border border-accent/40 rounded-lg px-3 py-2 text-[11px] text-paper/55 flex items-center justify-between">
        <span>Seleziona provider…</span>
        <span class="text-paper/35 text-[10px]">▾</span>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-2.5">
      <div>
        <label class="text-[10px] uppercase tracking-[0.15em] text-paper/45 font-medium block mb-1">Nome Prop</label>
        <div class="bg-white/[0.04] border border-white/[0.08] rounded-lg px-3 py-2 text-[11px] font-mono text-paper">PROP_01</div>
      </div>
      <div>
        <label class="text-[10px] uppercase tracking-[0.15em] text-paper/45 font-medium block mb-1">Visualizzato</label>
        <div class="bg-white/[0.04] border border-white/[0.08] rounded-lg px-3 py-2 text-[11px] font-mono text-paper">TSE_A001</div>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-2.5">
      <div>
        <label class="text-[10px] uppercase tracking-[0.15em] text-paper/45 font-medium block mb-1">Fase</label>
        <div class="bg-white/[0.04] border border-white/[0.08] rounded-lg px-3 py-2 text-[11px] text-paper/80 flex items-center justify-between">
          <span>Fase 1</span>
          <span class="text-paper/35 text-[10px]">▾</span>
        </div>
      </div>
      <div>
        <label class="text-[10px] uppercase tracking-[0.15em] text-paper/45 font-medium block mb-1">Piattaforma</label>
        <div class="bg-white/[0.04] border border-white/[0.08] rounded-lg px-3 py-2 text-[11px] text-paper/40 italic">auto da provider</div>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-2.5">
      <div>
        <label class="text-[10px] uppercase tracking-[0.15em] text-paper/45 font-medium block mb-1">Balance</label>
        <div class="bg-white/[0.04] border border-white/[0.08] rounded-lg px-3 py-2 text-[11px] font-mono text-paper tabular-nums">100.000 $</div>
      </div>
      <div>
        <label class="text-[10px] uppercase tracking-[0.15em] text-paper/45 font-medium block mb-1">Utente</label>
        <div class="bg-white/[0.04] border border-white/[0.08] rounded-lg px-3 py-2 text-[11px] text-paper/40 flex items-center justify-between">
          <span>Seleziona utente</span>
          <span class="text-paper/35 text-[10px]">▾</span>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-3 gap-2.5">
      <div>
        <label class="text-[10px] uppercase tracking-[0.15em] text-paper/45 font-medium block mb-1">Loss</label>
        <div class="bg-white/[0.04] border border-white/[0.08] rounded-lg px-3 py-2 text-[11px] font-mono text-paper tabular-nums">3.000 $</div>
      </div>
      <div>
        <label class="text-[10px] uppercase tracking-[0.15em] text-paper/45 font-medium block mb-1">Costo</label>
        <div class="bg-white/[0.04] border border-white/[0.08] rounded-lg px-3 py-2 text-[11px] font-mono text-paper tabular-nums">500 $</div>
      </div>
      <div>
        <label class="text-[10px] uppercase tracking-[0.15em] text-paper/45 font-medium block mb-1">Data</label>
        <div class="bg-white/[0.04] border border-white/[0.08] rounded-lg px-3 py-2 text-[11px] font-mono text-paper/55">gg/mm/aaaa</div>
      </div>
    </div>
  </div>
</div>
