---
import PageLayout from "../../layouts/PageLayout.astro";
import { getCollection, type CollectionEntry } from "astro:content";

const docs = (await getCollection("docs", ({ data }) => data.locale === "it"))
  .sort((a, b) => a.data.order - b.data.order);

const grouped = docs.reduce<Record<string, CollectionEntry<"docs">[]>>((acc, d) => {
  (acc[d.data.category] ||= []).push(d);
  return acc;
}, {});

const labels: Record<string, string> = {
  setup: "Setup", operations: "Operatività", troubleshooting: "Troubleshooting", billing: "Pagamenti",
};
---
<PageLayout title="Docs" description="Guide e setup per usare futugrana." locale="it">
  <section class="bg-paper px-8 pt-32 pb-24">
    <div class="max-w-[1000px] mx-auto">
      <h1 class="text-[clamp(56px,8vw,128px)] font-black tracking-[-0.04em] leading-[0.95] mb-12">Docs.</h1>
      {docs.length === 0 ? (
        <p class="text-xl text-ink/60 italic">Le guide saranno pubblicate prima del lancio commerciale.</p>
      ) : (
        <div class="space-y-12">
          {Object.entries(grouped).map(([cat, items]) => (
            <div>
              <h2 class="text-xs uppercase tracking-[0.3em] text-ink/50 font-semibold mb-4">{labels[cat] ?? cat}</h2>
              <ul class="space-y-2">
                {items.map((d) => (
                  <li><a href={`/docs/${d.id}`} class="text-lg font-bold hover:opacity-60">{d.data.title}</a></li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>
</PageLayout>
