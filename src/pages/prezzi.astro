---
import PageLayout from "../layouts/PageLayout.astro";
import PricingCards from "../components/PricingCards.astro";

const faqs = [
  { q: "Quando inizio a pagare?", a: "Il piano si attiva sugli account funded. Per gli account in evaluation la gestione operativa è gratuita." },
  { q: "Posso cambiare piano?", a: "Sì, in qualsiasi momento dalla dashboard. Cambia da Solo a Team o viceversa." },
  { q: "Cosa succede se un account viene chiuso?", a: "Lo slot si libera e il piano si riallinea automaticamente sugli account ancora attivi." },
  { q: "Quali metodi di pagamento accettate?", a: "Carta di credito (Stripe) e SEPA. Niente PayPal per ora." },
  { q: "Posso provarla senza impegno?", a: "Sì. La gestione operativa sugli account in evaluation è gratuita: la usi tutto il tempo che vuoi prima di attivare un piano." },
];
---
<PageLayout title="Prezzi" description="Tre piani per trader, un quarto per chi coordina una squadra." locale="it">
  <section class="bg-paper px-8 pt-32 pb-12">
    <div class="max-w-[1200px] mx-auto text-center">
      <h1 class="text-[clamp(28px,4vw,64px)] font-black tracking-[-0.04em] leading-[0.95] mb-6">Prezzi.</h1>
      <p class="text-xl text-ink/60 max-w-2xl mx-auto font-medium">
        I piani si attivano sugli account funded. Per gli account in evaluation la gestione operativa è gratuita.
      </p>
    </div>
  </section>

  <PricingCards locale="it" />

  <section class="bg-paper px-8 py-24">
    <div class="max-w-[760px] mx-auto">
      <h2 class="text-[clamp(20px,2.5vw,36px)] font-black tracking-[-0.04em] leading-[0.95] mb-12 text-center">
        Domande frequenti.
      </h2>
      <div class="space-y-4">
        {faqs.map((f) => (
          <details class="bg-ink/[0.03] rounded-2xl p-6 cursor-pointer group">
            <summary class="font-bold text-lg list-none flex justify-between items-center">
              <span>{f.q}</span>
              <span class="text-2xl group-open:rotate-45 transition-transform">+</span>
            </summary>
            <p class="text-base opacity-80 mt-4 font-medium leading-relaxed">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</PageLayout>
