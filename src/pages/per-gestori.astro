---
import PageLayout from "../layouts/PageLayout.astro";
import ScenePatternA from "../components/ScenePatternA.astro";
---
<PageLayout title="Per Gestori" description="Gestisci la tua squadra di trader. Davvero." locale="it">
  <section class="relative bg-blu text-paper min-h-screen flex items-center px-8 py-24" style="z-index: 10;">
    <div class="max-w-[1200px] mx-auto">
      <p class="text-xs uppercase tracking-[0.3em] opacity-50 mb-6">Per chi gestisce 5-20 trader</p>
      <h1 class="text-[clamp(56px,9vw,140px)] font-black tracking-[-0.04em] leading-[0.95] mb-8">
        Gestisci la tua squadra<br>di trader. Davvero.
      </h1>
      <p class="text-xl opacity-80 max-w-2xl mb-12 font-medium">
        Vedi chi performa. Traccia versato e incassato per ognuno. Paga i payout senza Excel.
      </p>
      <a href="#preventivo" class="inline-block px-9 py-4 bg-paper text-blu rounded-full font-bold hover:opacity-90">
        Richiedi preventivo →
      </a>
    </div>
  </section>

  <ScenePatternA bgClass="bg-celeste" eyebrow="01 — multi-trader scoping" title="Ogni trader vede solo i suoi.<br>Tu vedi tutti." wordLeft="ogni" wordRight="suo" zIndex={11}>
    <div class="w-full h-full bg-gradient-to-b from-[#1a2540] to-[#0a0e1a] text-paper flex items-center justify-center p-12">
      <div class="text-center max-w-2xl">
        <p class="text-xl font-medium opacity-80 leading-relaxed">RLS multi-tenant. Niente dati incrociati per sbaglio. Trader vede solo le sue prop, i suoi movimenti, i suoi payout. Tu, da admin, vedi tutto aggregato e filtrato.</p>
      </div>
    </div>
  </ScenePatternA>

  <ScenePatternA bgClass="bg-giallo" eyebrow="02 — verità sul netto" title="Numeri veri per ogni trader.<br>Real-time." wordLeft="i numeri" wordRight="veri" zIndex={12}>
    <div class="w-full h-full bg-gradient-to-b from-[#1a2540] to-[#0a0e1a] text-paper flex items-center justify-center p-12">
      <div class="text-center max-w-2xl">
        <p class="text-xl font-medium opacity-80 leading-relaxed">Recovery exit_price + WS worker. Sai quanto incassa ognuno, davvero. Quando il broker chiude prima, il sistema recupera il vero PnL in 200-500ms.</p>
      </div>
    </div>
  </ScenePatternA>

  <ScenePatternA bgClass="bg-viola" eyebrow="03 — contabilità integrata" title="Versato, incassato, payout.<br>Per ogni trader, per ogni prop." wordLeft="contabilità" wordRight="per ognuno" zIndex={13}>
    <div class="w-full h-full bg-paper text-ink flex items-center justify-center p-12">
      <div class="text-center max-w-2xl">
        <p class="text-xl font-medium opacity-80 leading-relaxed">Movimenti tracciati, dossier annuale pulito, niente Excel cross-trader. Esporti CSV pronto per il commercialista.</p>
      </div>
    </div>
  </ScenePatternA>

  <ScenePatternA bgClass="bg-celeste-2" textClass="text-paper" eyebrow="04 — multi-broker reale" title="Tradovate. MetaApi. ProjectX.<br>Tutti i broker. Tutti i trader." wordLeft="tutti i" wordRight="broker" zIndex={14}>
    <div class="w-full h-full bg-gradient-to-b from-[#2a1065] to-[#4c1d95] text-paper flex items-center justify-center p-12">
      <div class="text-center max-w-2xl">
        <p class="text-xl font-medium opacity-80 leading-relaxed">Connessione provider per ogni trader, indipendente, isolata. Apex, FTMO, Topstep, Lucid, Tradeify — tutti i mix possibili tra i tuoi.</p>
      </div>
    </div>
  </ScenePatternA>

  <section id="preventivo" class="bg-paper px-8 py-24 relative" style="z-index: 25;">
    <div class="max-w-[760px] mx-auto">
      <h2 class="text-[clamp(40px,5vw,72px)] font-black tracking-[-0.04em] leading-[0.95] mb-4 text-center">
        Costruiamo insieme il tuo piano.
      </h2>
      <p class="text-center text-ink/60 mb-12 text-base font-medium">
        Compilala in 2 minuti. Ti rispondiamo entro 24h con una proposta di pricing personalizzata.
      </p>

      <form
        action="https://formspree.io/f/REPLACE_ME"
        method="POST"
        class="space-y-5"
      >
        <div>
          <label class="block text-sm font-bold mb-2">Nome e cognome *</label>
          <input type="text" name="name" required class="w-full px-4 py-3 bg-ink/5 border-2 border-ink/10 rounded-xl focus:border-ink focus:outline-none font-medium" />
        </div>
        <div>
          <label class="block text-sm font-bold mb-2">Email *</label>
          <input type="email" name="email" required class="w-full px-4 py-3 bg-ink/5 border-2 border-ink/10 rounded-xl focus:border-ink focus:outline-none font-medium" />
        </div>
        <div>
          <label class="block text-sm font-bold mb-2">Numero di trader gestiti *</label>
          <select name="team_size" required class="w-full px-4 py-3 bg-ink/5 border-2 border-ink/10 rounded-xl focus:border-ink focus:outline-none font-medium">
            <option value="">Seleziona...</option>
            <option value="1-5">1-5</option>
            <option value="6-10">6-10</option>
            <option value="11-20">11-20</option>
            <option value="20+">20+</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-bold mb-2">Prop firm utilizzate</label>
          <input type="text" name="prop_firms" placeholder="es. APEX, FTMO, Topstep..." class="w-full px-4 py-3 bg-ink/5 border-2 border-ink/10 rounded-xl focus:border-ink focus:outline-none font-medium" />
        </div>
        <div>
          <label class="block text-sm font-bold mb-2">Messaggio (opzionale)</label>
          <textarea name="message" rows="4" class="w-full px-4 py-3 bg-ink/5 border-2 border-ink/10 rounded-xl focus:border-ink focus:outline-none font-medium"></textarea>
        </div>
        <button type="submit" class="w-full px-9 py-4 bg-ink text-paper rounded-full font-bold hover:opacity-90">
          Invia richiesta →
        </button>
      </form>
    </div>
  </section>
</PageLayout>
