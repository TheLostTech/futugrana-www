---
import PageLayout from "../../layouts/PageLayout.astro";
import Hero from "../../components/Hero.astro";
import ScenePatternA from "../../components/ScenePatternA.astro";
import HedgeMock from "../../components/HedgeMock.astro";
import KpiLogMock from "../../components/KpiLogMock.astro";
import MultiBrokerMock from "../../components/MultiBrokerMock.astro";
import LedgerMock from "../../components/LedgerMock.astro";
import FlowSection from "../../components/FlowSection.astro";
import PricingCards from "../../components/PricingCards.astro";
import TrustRow from "../../components/TrustRow.astro";
import PreFooterCTA from "../../components/PreFooterCTA.astro";
---
<PageLayout title="futugrana" locale="en">
  <Hero locale="en" />
  <ScenePatternA bgClass="bg-verde-menta" wordsClass="text-ink/[0.04]" eyebrow="01 — coordination" title="Synchronized<br>environments." wordLeft="coordinated" wordRight="execution" zIndex={11}>
    <HedgeMock />
  </ScenePatternA>
  <ScenePatternA bgClass="bg-giallo" wordsClass="text-ink/[0.04]" eyebrow="02 — visibility" title="Clear<br>operational state." wordLeft="state" wordRight="visible" zIndex={12}>
    <KpiLogMock />
  </ScenePatternA>
  <ScenePatternA bgClass="bg-viola" wordsClass="text-ink/[0.05]" eyebrow="03 — multi-broker" title="Tradovate.<br>MetaApi. ProjectX." wordLeft="environments" wordRight="connected" zIndex={13}>
    <MultiBrokerMock />
  </ScenePatternA>
  <ScenePatternA bgClass="bg-celeste-2" textClass="text-paper" wordsClass="text-paper/[0.06]" eyebrow="04 — bookkeeping" title="Movements<br>on the record." wordLeft="movements" wordRight="tracked" zIndex={14}>
    <LedgerMock />
  </ScenePatternA>
  <FlowSection locale="en" />
  <PricingCards locale="en" />
  <TrustRow locale="en" />
  <PreFooterCTA locale="en" />
</PageLayout>
