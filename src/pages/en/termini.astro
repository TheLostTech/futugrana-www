---
import PageLayout from "../../layouts/PageLayout.astro";
import EnPlaceholderBanner from "../../components/EnPlaceholderBanner.astro";
---
<PageLayout title="Terms" description="Terms and conditions." locale="en">
  <EnPlaceholderBanner />
  <section class="bg-paper px-8 pt-32 pb-24">
    <div class="max-w-[760px] mx-auto">
      <h1 class="text-[clamp(48px,6vw,96px)] font-black tracking-[-0.04em] leading-[0.95] mb-8">Terms.</h1>
      <p class="text-base text-ink/70 italic">Document in progress. Contact <a href="mailto:legal@futugrana.com" class="underline">legal@futugrana.com</a>.</p>
    </div>
  </section>
</PageLayout>
