---
import PageLayout from "../../layouts/PageLayout.astro";
import PricingCards from "../../components/PricingCards.astro";
import EnPlaceholderBanner from "../../components/EnPlaceholderBanner.astro";

const faqs = [
  { q: "When do I start paying?", a: "Plans activate on funded accounts. Operational management is free for evaluation accounts." },
  { q: "Can I switch plans?", a: "Yes, anytime from the dashboard." },
  { q: "What happens if an account is closed?", a: "The slot frees up and the plan automatically re-aligns to the still-active accounts." },
  { q: "Which payment methods do you accept?", a: "Credit card (Stripe) and SEPA." },
  { q: "Can I try it without commitment?", a: "Yes. Operational management on evaluation accounts is free — use it as long as you want before activating a plan." },
];
---
<PageLayout title="Pricing" description="Three plans for traders, a fourth for those who coordinate a team." locale="en">
  <EnPlaceholderBanner />
  <section class="bg-paper px-8 pt-32 pb-12">
    <div class="max-w-[1200px] mx-auto text-center">
      <h1 class="text-[clamp(28px,4vw,64px)] font-black tracking-[-0.04em] leading-[0.95] mb-6">Pricing.</h1>
      <p class="text-xl text-ink/60 max-w-2xl mx-auto font-medium">
        Plans activate on funded accounts. Operational management is free for evaluation accounts.
      </p>
    </div>
  </section>

  <PricingCards locale="en" />

  <section class="bg-paper px-8 py-24">
    <div class="max-w-[760px] mx-auto">
      <h2 class="text-[clamp(20px,2.5vw,36px)] font-black tracking-[-0.04em] leading-[0.95] mb-12 text-center">
        Frequently asked questions.
      </h2>
      <div class="space-y-4">
        {faqs.map((f) => (
          <details class="bg-ink/[0.03] rounded-2xl p-6 cursor-pointer group">
            <summary class="font-bold text-lg list-none flex justify-between items-center">
              <span>{f.q}</span>
              <span class="text-2xl group-open:rotate-45 transition-transform">+</span>
            </summary>
            <p class="text-base opacity-80 mt-4 font-medium leading-relaxed">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</PageLayout>
