---
import PageLayout from "../../layouts/PageLayout.astro";
import CommissionCalculator from "../../components/CommissionCalculator.tsx";
import EnPlaceholderBanner from "../../components/EnPlaceholderBanner.astro";

const appUrl = "https://app.futugrana.com";
---
<PageLayout title="Become partner" description="Bring a trader. Cash with them." locale="en">
  <EnPlaceholderBanner />
  <section class="bg-blu text-paper px-8 py-32 relative" style="z-index: 10;">
    <div class="max-w-[1100px] mx-auto text-center">
      <p class="text-xs uppercase tracking-[0.3em] opacity-50 mb-6">Referral program</p>
      <h1 class="text-[clamp(28px,4.5vw,70px)] font-black tracking-[-0.04em] leading-[0.95] mb-8">
        Bring a trader.<br>Cash with them.
      </h1>
      <p class="text-xl opacity-80 max-w-2xl mx-auto mb-12 font-medium">
        Promote futugrana to traders you know. When one goes FUNDED and activates a slot, you earn a recurring commission.
      </p>
      <a href={`${appUrl}/signup?role=promoter`} class="inline-block px-9 py-4 bg-paper text-blu rounded-full font-bold hover:opacity-90">
        Become partner →
      </a>
    </div>
  </section>

  <section class="bg-paper px-8 py-24 relative" style="z-index: 20;">
    <div class="max-w-[1100px] mx-auto">
      <CommissionCalculator client:load />
    </div>
  </section>
</PageLayout>
