---
import PageLayout from "../layouts/PageLayout.astro";
import Hero from "../components/Hero.astro";
import ScenePatternA from "../components/ScenePatternA.astro";
import ScenePatternB from "../components/ScenePatternB.astro";
import HedgeMock from "../components/HedgeMock.astro";
import KpiLogMock from "../components/KpiLogMock.astro";
import MultiBrokerMock from "../components/MultiBrokerMock.astro";
import LedgerMock from "../components/LedgerMock.astro";
import FlowSection from "../components/FlowSection.astro";
import PricingCards from "../components/PricingCards.astro";
import TrustRow from "../components/TrustRow.astro";
import PreFooterCTA from "../components/PreFooterCTA.astro";
---
<PageLayout title="futugrana" locale="it">
  <Hero locale="it" />

  <ScenePatternA
    bgClass="bg-verde-menta"
    textClass="text-ink"
    wordsClass="text-ink/[0.04]"
    eyebrow="01 — coordinamento"
    title="Ambienti<br>sincronizzati."
    wordLeft="esecuzione"
    wordRight="coordinata"
    zIndex={11}
  >
    <HedgeMock />
  </ScenePatternA>

  <ScenePatternB
    bgClass="bg-giallo"
    textClass="text-ink/[0.05]"
    titleClass="text-ink"
    eyebrow="02 — visibilità"
    title="Stato operativo<br>chiaro."
    wordTop="stato"
    wordBottom="chiaro"
    zIndex={12}
  >
    <KpiLogMock />
  </ScenePatternB>

  <ScenePatternA
    bgClass="bg-viola"
    textClass="text-ink"
    wordsClass="text-ink/[0.05]"
    eyebrow="03 — multi-broker"
    title="Tradovate.<br>MetaApi. ProjectX."
    wordLeft="ambienti"
    wordRight="collegati"
    zIndex={13}
  >
    <MultiBrokerMock />
  </ScenePatternA>

  <ScenePatternB
    bgClass="bg-celeste-2"
    textClass="text-paper/[0.06]"
    titleClass="text-paper"
    eyebrow="04 — registro"
    title="Movimenti<br>tracciati."
    wordTop="movimenti"
    wordBottom="tracciati"
    zIndex={14}
  >
    <LedgerMock />
  </ScenePatternB>

  <FlowSection locale="it" />
  <PricingCards locale="it" />
  <TrustRow locale="it" />
  <PreFooterCTA locale="it" />
</PageLayout>
